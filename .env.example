# Copiar a .env y completar. NUNCA commitear .env (esta en .gitignore).

# --- Telegram (alertas y reporte diario) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Modo de ejecución del bot ---
# simulate = sin keys, registra al precio público (arrancá acá)
# testnet  = órdenes reales en testnet de Binance (plata FALSA)
# live     = plata REAL (solo Fase 3, con autorización explícita)
BOT_MODE=simulate

# --- Binance API (solo testnet/live; NO necesario para simulate ni backtest) ---
# Testnet: crear en https://testnet.binance.vision
# Live: crear en Binance con permisos SOLO de Spot Trading. NUNCA habilitar retiros.
BINANCE_API_KEY=
BINANCE_API_SECRET=
